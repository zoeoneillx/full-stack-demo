# Copy to .env and fill in values as needed.
# All variables are optional — the app works with zero configuration.

# Port the Express server listens on (default: 3000)
PORT=3000

# Override the base URL used by Playwright tests (default: http://localhost:3000)
BASE_URL=http://localhost:3000

# E8 — Set to "1" to flip the "Create User" button label to "Add User".
# This makes previously-passing tests go red — used in the false-green lesson.
DEMO_BREAK=

# Optional: GitHub token for qflow AI features (not required for any exercise)
# GITHUB_TOKEN=
